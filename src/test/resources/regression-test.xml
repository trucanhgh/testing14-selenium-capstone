<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Framework Regression Suite">
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>

    <test name="Auth Regression" preserve-order="true" verbose="2">
        <classes>
            <class name="testcase.ui.auth.LoginTest"/>
        </classes>
    </test>
</suite>